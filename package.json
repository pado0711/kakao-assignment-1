{
  "name": "kakao-assignment-1-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx http-server ./ -p 3000",
    "test": "node --test",
    "lint": "eslint . --max-warnings=0",
    "lint:report": "eslint . --format json --output-file eslint-report.json",
    "coverage": "c8 --reporter=text --reporter=lcov --reporter=json-summary node --test",
    "ci": "npm run lint && npm run coverage"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-sonarjs": "^0.25.1",
    "http-server": "^14.1.1"
  }
}

{
  "name": "kakao-todo-fullstack",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "backend/.venv/bin/uvicorn main:app --reload --app-dir backend",
    "test:frontend": "npm --workspace frontend run test",
    "test:backend": "backend/.venv/bin/pytest backend -q",
    "test": "npm run test:backend && npm run test:frontend",
    "lint": "npm --workspace frontend run lint",
    "lint:report": "npm --workspace frontend run lint:report",
    "build": "npm --workspace frontend run build",
    "coverage": "npm --workspace frontend run coverage",
    "ci": "npm run test && npm run lint && npm run build"
  }
}

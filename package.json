{
  "name": "kakao-todo-fullstack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "backend/.venv/bin/uvicorn main:app --reload --app-dir backend",
    "test:frontend": "npm --prefix frontend test",
    "test:backend": "backend/.venv/bin/pytest backend -q",
    "test": "npm run test:backend && npm run test:frontend",
    "lint": "npm --prefix frontend run lint",
    "build": "npm --prefix frontend run build",
    "coverage": "npm --prefix frontend run coverage",
    "ci": "npm run test && npm run lint && npm run build"
  }
}
